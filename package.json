        "title": "m3270: Colors & appearance"
      },
      {
        "command": "m3270.connect",
        "title": "m3270: Connect"
      },
      {
        "command": "m3270.showLog",
        "title": "m3270: Show Connection Log"
      },
      {
        "command": "m3270.disconnect",
        "title": "m3270: Disconnect"
      },
      {
        "command": "m3270.enter",
        "title": "m3270: Enter"
      },
      {
        "command": "m3270.clear",
        "title": "m3270: Clear Screen"
      },
      {
