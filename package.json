{
  "name": "m3270",
  "displayName": "m3270",
  "description": "A basic 3270-style terminal emulator for VS Code with a programmatic control API.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:m3270.open",
    "onCommand:m3270.settings",
    "onCommand:m3270.connect",
