    "onCommand:m3270.pf16",
    "onCommand:m3270.pf17",
    "onCommand:m3270.pf18",
    "onCommand:m3270.pf19",
    "onCommand:m3270.pf20",
    "onCommand:m3270.pf21",
    "onCommand:m3270.pf22",
    "onCommand:m3270.pf23",
    "onCommand:m3270.pf24",
    "onCommand:m3270.pa1",
