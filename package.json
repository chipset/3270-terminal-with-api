      {
        "command": "m3270.fieldExit",
        "title": "m3270: Field Exit"
      },
      {
        "command": "m3270.tab",
        "title": "m3270: Next Field"
      },
      {
        "command": "m3270.backtab",
        "title": "m3270: Previous Field"
      }
    ],
    "keybindings": [
      {
        "command": "m3270.backtab",
        "key": "shift+tab",
        "mac": "shift+tab",
        "when": "webviewId == 'm3270.emulator'"
      }
    ],
    "configuration": {
      "title": "m3270",
      "properties": {
        "m3270.hostname": {
          "type": "string",
          "default": "",
          "description": "Default host name for 3270 connections."
        },
        "m3270.port": {
          "type": "number",
          "default": 23,
          "description": "Default host port for 3270 connections."
        },
        "m3270.secure": {
          "type": "boolean",
          "default": false,
          "description": "Connect with TLS."
        },
        "m3270.rejectUnauthorized": {
          "type": "boolean",
          "default": true,
          "description": "Reject unauthorized TLS certificates."
        },
        "m3270.terminalType": {
          "type": "string",
          "default": "IBM-3278-2-E",
          "description": "TN3270 terminal type sent during telnet negotiation."
        },
        "m3270.deviceName": {
          "type": "string",
          "default": "",
          "description": "Optional device or LU name appended to the terminal type when requested by the host."
        },
        "m3270.connectionTimeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "TCP/TLS connection timeout in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "validate": "node test/emulator.test.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}
