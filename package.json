      },
      {
        "command": "m3270.pf11",
        "title": "m3270: PF11"
      },
      {
        "command": "m3270.pf12",
        "title": "m3270: PF12"
      },
      {
        "command": "m3270.pf13",
        "title": "m3270: PF13"
