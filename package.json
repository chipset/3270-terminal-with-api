    "onCommand:m3270.pa3",
    "onCommand:m3270.fieldExit",
    "onCommand:m3270.tab",
    "onCommand:m3270.backtab"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "m3270.open",
        "title": "m3270: Open Emulator"
      },
      {
        "command": "m3270.settings",
        "title": "m3270: Connection Settings"
      },
      {
        "command": "m3270.connect",
        "title": "m3270: Connect"
      },
      {
        "command": "m3270.showLog",
        "title": "m3270: Show Connection Log"
      },
